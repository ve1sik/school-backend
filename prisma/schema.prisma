generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL") // 🔥 Вот она, спасительная строчка для Supabase!
}

// --- РОЛИ И ТИПЫ ---
enum Role {
  STUDENT
  CURATOR
  ADMIN
  PARENT
}

enum QuestionType {
  AUTO
  MANUAL
  ORAL
}

enum LessonType {
  VIDEO
  TEXT
  TEST
}

enum SubmissionStatus {
  PENDING
  GRADED
}

// 🔥 НОВОЕ: Типы событий для расписания
enum EventType {
  WEBINAR
  DEADLINE
  OFFLINE
}

// --- ТАБЛИЦЫ ---
model User {
  id            String  @id @default(uuid())
  email         String  @unique
  password_hash String
  role          Role    @default(STUDENT)
  refresh_token String?

  name       String?
  surname    String?
  patronymic String?
  birthday   String?
  city       String?
  avatar     String? @db.Text

  invite_code String? @unique
  parent_id   String?
  parent      User?   @relation("ParentChildren", fields: [parent_id], references: [id])
  children    User[]  @relation("ParentChildren")

  created_at DateTime @default(now())

  test_attempts TestAttempt[]
  enrollments   Enrollment[]
  submissions   Submission[]

  // 🔥 НОВОЕ: Связи с группами
  groups         Group[] @relation("StudentGroups") // Группы, в которых учится студент
  curated_groups Group[] @relation("CuratorGroups") // Группы, которые ведет куратор

  @@map("users")
}

// 🔥 НОВОЕ: Модель Группы (Потока)
model Group {
  id         String   @id @default(uuid())
  title      String   // Название (например, "ОГЭ История - Сентябрь")
  created_at DateTime @default(now())

  // Связь с Куратором
  curator_id String?
  curator    User?    @relation("CuratorGroups", fields: [curator_id], references: [id])

  // Связи со студентами, курсами и расписанием
  students   User[]   @relation("StudentGroups")
  courses    Course[] @relation("GroupCourses")
  events     Event[]  // Изолированное расписание группы

  // Настройки доступа к модулям (Drip Content)
  theme_access GroupThemeAccess[]

  @@map("groups")
}

// 🔥 НОВОЕ: Капельное открытие контента (Drip Content)
model GroupThemeAccess {
  id          String    @id @default(uuid())
  group_id    String
  theme_id    String
  unlock_date DateTime? // Дата, когда модуль откроется (если null - открыт сразу)
  is_visible  Boolean   @default(true) // Можно вообще скрыть модуль от группы

  group Group @relation(fields: [group_id], references: [id], onDelete: Cascade)
  theme Theme @relation(fields: [theme_id], references: [id], onDelete: Cascade)

  @@unique([group_id, theme_id]) // В одной группе не может быть двух настроек для одного модуля
  @@map("group_theme_access")
}

model Course {
  id          String  @id @default(uuid())
  title       String
  description String? @db.Text
  cover_url   String?

  themes      Theme[]
  enrollments Enrollment[]
  
  // 🔥 НОВОЕ: Курсы, доступные определенным группам
  groups      Group[] @relation("GroupCourses")

  @@map("courses")
}

model Theme {
  id          String  @id @default(uuid())
  course_id   String
  title       String
  order_index Int
  is_visible  Boolean @default(true)

  course Course   @relation(fields: [course_id], references: [id], onDelete: Cascade)
  lessons Lesson[]
  tests   Test[]

  // 🔥 НОВОЕ: Связь для настроек доступа по группам
  group_access GroupThemeAccess[]

  @@map("themes")
}

model Lesson {
  id          String     @id @default(uuid())
  title       String
  type        LessonType @default(VIDEO)
  video_url   String?
  content     String?    @db.Text
  test_data   Json?
  is_visible  Boolean    @default(true)
  order_index Int
  theme_id    String

  theme      Theme    @relation(fields: [theme_id], references: [id], onDelete: Cascade)
  created_at DateTime @default(now())

  submissions Submission[]

  is_homework Boolean @default(false)

  @@map("lessons")
}

model Test {
  id           String @id @default(uuid())
  theme_id     String
  title        String
  max_attempts Int    @default(1)

  theme     Theme         @relation(fields: [theme_id], references: [id], onDelete: Cascade)
  questions Question[]
  attempts  TestAttempt[]

  @@map("tests")
}

model Question {
  id             String       @id @default(uuid())
  test_id        String
  type           QuestionType @default(AUTO)
  content        String       @db.Text
  correct_answer String?      @db.Text
  points         Int          @default(1)

  test    Test     @relation(fields: [test_id], references: [id], onDelete: Cascade)
  answers Answer[]

  @@map("questions")
}

model TestAttempt {
  id             String   @id @default(uuid())
  test_id        String
  user_id        String
  score          Int      @default(0)
  attempt_number Int
  created_at     DateTime @default(now())

  test    Test     @relation(fields: [test_id], references: [id], onDelete: Cascade)
  user    User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  answers Answer[]

  @@map("test_attempts")
}

model Answer {
  id             String  @id @default(uuid())
  attempt_id     String
  question_id    String
  user_answer    String  @db.Text
  is_correct     Boolean @default(false)
  points_awarded Int     @default(0)

  attempt  TestAttempt @relation(fields: [attempt_id], references: [id], onDelete: Cascade)
  question Question    @relation(fields: [question_id], references: [id], onDelete: Cascade)

  @@map("answers")
}

model Enrollment {
  id         String   @id @default(uuid())
  user_id    String
  course_id  String
  created_at DateTime @default(now())

  user   User   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  course Course @relation(fields: [course_id], references: [id], onDelete: Cascade)

  @@map("enrollments")
}

model Submission {
  id         String           @id @default(uuid())
  user_id    String
  lesson_id  String
  block_id   String
  question   String           @db.Text
  answer     String           @db.Text
  max_score  Int              @default(3)
  score      Int?
  comment    String?          @db.Text
  status     SubmissionStatus @default(PENDING)
  created_at DateTime         @default(now())
  updated_at DateTime         @updatedAt

  user   User   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lesson_id], references: [id], onDelete: Cascade)

  @@map("submissions")
}

model Event {
  id          String    @id @default(uuid())
  title       String
  description String?   @db.Text
  date        DateTime
  type        EventType @default(WEBINAR)
  link        String?
  created_at  DateTime  @default(now())

  // 🔥 НОВОЕ: Привязка события к конкретной группе
  group_id    String?
  group       Group?    @relation(fields: [group_id], references: [id], onDelete: Cascade)

  @@map("events")
}