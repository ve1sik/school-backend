generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// --- РОЛИ И ТИПЫ ---
enum Role {
  STUDENT
  CURATOR
  TEACHER
  ADMIN
  PARENT
}

enum QuestionType {
  AUTO
  MANUAL
  ORAL
}

enum LessonType {
  VIDEO
  TEXT
  TEST
}

enum SubmissionStatus {
  PENDING
  GRADED
  REVISION
}

enum EventType {
  WEBINAR
  DEADLINE
  OFFLINE
}

enum GroupKind {
  STUDY
  STREAM
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

// --- ТАБЛИЦЫ ---
model User {
  id            String  @id @default(uuid())
  email         String  @unique
  password_hash String
  role          Role    @default(STUDENT)
  refresh_token String?
  admin_permissions String[] @default([])

  name       String?
  surname    String?
  patronymic String?
  birthday   String?
  city       String?
  avatar     String? @db.Text

  // 🎮 Геймификация: накопительные очки за активность
  points     Int     @default(0)

  invite_code String? @unique
  parent_id   String?
  parent      User?   @relation("ParentChildren", fields: [parent_id], references: [id])
  children    User[]  @relation("ParentChildren")

  telegram_chat_id   String?   @unique
  telegram_link_code String?   @unique
  telegram_linked_at DateTime?

  created_at DateTime @default(now())

  test_attempts TestAttempt[]
  enrollments   Enrollment[]
  submissions   Submission[]
  ron_tasks     RonTask[]

  groups          Group[] @relation("StudentGroups")
  curated_groups  Group[] @relation("CuratorGroups")
  teaching_groups Group[] @relation("TeacherGroups")

  sent_messages     Message[] @relation("SentMessages")
  received_messages Message[] @relation("ReceivedMessages")
  flashcard_progress FlashcardProgress[]
  applications       GroupApplication[]

  subjects          Subject[] @relation("TeacherSubjects")

  @@map("users")
}


model Group {
  id           String    @id @default(uuid())
  title        String
  group_kind   GroupKind @default(STUDY)
  price        Int       @default(0)
  old_price    Int?     @default(0)
  start_date   String?
  badge        String?
  features     String[] @default(["Доступ ко всем урокам", "Проверка ДЗ", "Авторские конспекты"])
  is_public    Boolean  @default(true) 
  cover_url    String?

  // Реквизиты для оплаты (номер счёта, карты, комментарий)
  payment_info String?  @db.Text
  payment_qr_url String? @db.Text

  curator_id  String?
  curator     User?    @relation("CuratorGroups", fields: [curator_id], references: [id])
  teacher_id  String?
  teacher     User?    @relation("TeacherGroups", fields: [teacher_id], references: [id])
  students    User[]   @relation("StudentGroups")
  courses     Course[] @relation("GroupCourses")
  events      Event[]  

  theme_access GroupThemeAccess[]
  applications GroupApplication[]

  @@map("groups")
}


model GroupThemeAccess {
  id          String    @id @default(uuid())
  group_id    String
  theme_id    String
  unlock_date DateTime? 
  deadline    DateTime?
  is_visible  Boolean   @default(true) 

  group Group @relation(fields: [group_id], references: [id], onDelete: Cascade)
  theme Theme @relation(fields: [theme_id], references: [id], onDelete: Cascade)

  @@unique([group_id, theme_id]) 
  @@map("group_theme_access")
}

model Course {
  id              String   @id @default(uuid())
  title           String
  description     String?  @db.Text
  cover_url       String?
  spell_check         Boolean  @default(false)
  oral_in_analytics   Boolean  @default(true)

  subject_id  String?
  subject     Subject? @relation(fields: [subject_id], references: [id], onDelete: Cascade)

  themes      Theme[]
  enrollments Enrollment[]
  
  groups      Group[] @relation("GroupCourses")

  @@map("courses")
}

model Theme {
  id          String    @id @default(uuid())
  course_id   String
  title       String
  order_index Int
  is_visible  Boolean   @default(true)
  unlock_date DateTime?
  deadline    DateTime?

  course Course   @relation(fields: [course_id], references: [id], onDelete: Cascade)
  lessons Lesson[]
  tests    Test[]

  group_access GroupThemeAccess[]

  @@index([course_id, order_index])
  @@map("themes")
}

model Lesson {
  id          String     @id @default(uuid())
  title       String
  type        LessonType @default(VIDEO)
  video_url   String?
  content     String?    @db.Text
  test_data   Json?
  is_visible  Boolean    @default(true)
  include_in_analytics Boolean @default(true)
  order_index Int
  theme_id    String
  unlock_date DateTime?
  deadline    DateTime?

  theme      Theme    @relation(fields: [theme_id], references: [id], onDelete: Cascade)
  created_at DateTime @default(now())

  submissions Submission[]
  ron_tasks   RonTask[]
  decks       Deck[]

  is_homework Boolean @default(false)

  @@index([theme_id, order_index])
  @@map("lessons")
}

model Test {
  id           String @id @default(uuid())
  theme_id     String
  title        String
  max_attempts Int    @default(1)

  theme      Theme         @relation(fields: [theme_id], references: [id], onDelete: Cascade)
  questions Question[]
  attempts  TestAttempt[]

  @@map("tests")
}

model Question {
  id             String       @id @default(uuid())
  test_id        String
  type           QuestionType @default(AUTO)
  content        String       @db.Text
  correct_answer String?      @db.Text
  points         Int          @default(1)

  test    Test     @relation(fields: [test_id], references: [id], onDelete: Cascade)
  answers Answer[]

  @@map("questions")
}

model TestAttempt {
  id             String   @id @default(uuid())
  test_id        String
  user_id        String
  score          Int      @default(0)
  attempt_number Int
  created_at     DateTime @default(now())

  test    Test     @relation(fields: [test_id], references: [id], onDelete: Cascade)
  user    User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  answers Answer[]

  @@index([user_id, test_id])
  @@map("test_attempts")
}

model Answer {
  id             String  @id @default(uuid())
  attempt_id     String
  question_id    String
  user_answer    String  @db.Text
  is_correct     Boolean @default(false)
  points_awarded Int     @default(0)

  attempt  TestAttempt @relation(fields: [attempt_id], references: [id], onDelete: Cascade)
  question Question    @relation(fields: [question_id], references: [id], onDelete: Cascade)

  @@map("answers")
}

model Enrollment {
  id         String    @id @default(uuid())
  user_id    String
  course_id  String
  created_at DateTime  @default(now())
  expires_at DateTime?

  user   User   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  course Course @relation(fields: [course_id], references: [id], onDelete: Cascade)

  @@unique([user_id, course_id])
  @@index([user_id])
  @@index([course_id])
  @@index([expires_at])
  @@map("enrollments")
}

model GroupApplication {
  id          String            @id @default(uuid())
  group_id    String
  user_id     String
  status      ApplicationStatus @default(PENDING)
  comment     String?           @db.Text
  proof_image String?           @db.Text
  reviewed_by String?
  created_at  DateTime          @default(now())
  reviewed_at DateTime?

  group Group @relation(fields: [group_id], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([group_id, user_id])
  @@index([group_id, status])
  @@map("group_applications")
}

model Submission {
  id         String           @id @default(uuid())
  user_id    String
  lesson_id  String
  block_id   String
  block_type String?
  question   String           @db.Text
  answer     String           @db.Text
  max_score  Int              @default(3)
  score      Int?
  comment    String?          @db.Text
  criteria_scores     Json?
  error_annotations   Json?
  status     SubmissionStatus @default(PENDING)
  created_at DateTime         @default(now())
  updated_at DateTime         @updatedAt

  user   User   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lesson_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([lesson_id])
  @@index([status])
  @@map("submissions")
}

model RonTask {
  id           String   @id @default(uuid())
  user_id      String
  lesson_id    String
  block_id     String
  block_data   String   @db.Text
  course_id    String?
  theme_id     String?
  course_title String?
  theme_title  String?
  lesson_title String?
  block_title  String?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  user   User   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lesson_id], references: [id], onDelete: Cascade)

  @@unique([user_id, lesson_id, block_id])
  @@index([user_id])
  @@map("ron_tasks")
}

model Event {
  id          String    @id @default(uuid())
  title       String
  description String?   @db.Text
  date        DateTime
  type        EventType @default(WEBINAR)
  custom_type String?
  link        String?
  created_at  DateTime  @default(now())

  group_id    String?
  group       Group?    @relation(fields: [group_id], references: [id], onDelete: Cascade)

  @@index([date])
  @@index([group_id])
  @@map("events")
}

model Message {
  id          String   @id @default(uuid())
  sender_id   String
  receiver_id String
  text        String   @db.Text
  is_read     Boolean  @default(false)
  created_at  DateTime @default(now())

  sender      User     @relation("SentMessages", fields: [sender_id], references: [id], onDelete: Cascade)
  receiver    User     @relation("ReceivedMessages", fields: [receiver_id], references: [id], onDelete: Cascade)

  @@index([sender_id])
  @@index([receiver_id])
  @@index([is_read])
  @@map("messages")
}

model Subject {
  id         String   @id @default(uuid())
  title      String   // Например: "Русский язык", "История"
  
  // Связь с конкретным преподавателем (если нужно будет ограничить доступ)
  teacher_id String?
  teacher    User?    @relation("TeacherSubjects", fields: [teacher_id], references: [id])

  // Связь с курсами (в одном предмете много курсов)
  courses    Course[]

  @@map("subjects")
}

// ──────────────────────────────────────────────
//  ФЛЕШ-КАРТОЧКИ (Spaced Repetition)
// ──────────────────────────────────────────────

model Deck {
  id          String      @id @default(uuid())
  title       String
  description String?
  lesson_id   String?
  lesson      Lesson?     @relation(fields: [lesson_id], references: [id], onDelete: SetNull)
  cards       Flashcard[]
  created_at  DateTime    @default(now())

  @@map("decks")
}

model Flashcard {
  id           String              @id @default(uuid())
  deck_id      String
  deck         Deck                @relation(fields: [deck_id], references: [id], onDelete: Cascade)
  front        String              @db.Text
  back         String              @db.Text
  front_image  String?             @db.Text
  back_image   String?             @db.Text
  order_index  Int                 @default(0)
  progress     FlashcardProgress[]
  created_at   DateTime            @default(now())

  @@map("flashcards")
}

model FlashcardProgress {
  id               String     @id @default(uuid())
  user_id          String
  user             User       @relation(fields: [user_id], references: [id], onDelete: Cascade)
  flashcard_id     String
  flashcard        Flashcard  @relation(fields: [flashcard_id], references: [id], onDelete: Cascade)
  interval         Int        @default(1)
  ease_factor      Float      @default(2.5)
  next_review_at   DateTime   @default(now())
  last_reviewed_at DateTime?
  repetitions      Int        @default(0)

  @@unique([user_id, flashcard_id])
  @@index([next_review_at])
  @@map("flashcard_progress")
}